{
  "name": "superhero-3d-customizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "verify-supabase": "node -e \"const ok=Boolean(process.env.VITE_SUPABASE_URL)&&Boolean(process.env.VITE_SUPABASE_ANON_KEY); console.log(ok ? 'Supabase env vars found.' : 'Missing VITE_SUPABASE_URL or VITE_SUPABASE_ANON_KEY.'); process.exit(ok ? 0 : 1)\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
